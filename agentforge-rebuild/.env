# AgentForge Phase 3 - Ollama (Offline) Configuration

# === LLM Providers ===
# Ollama is the default (100% free, offline)
# Grok is optional (faster online responses)

# Optional: Grok API key (only if you want to use Grok provider)
# GROK_API_KEY=gsk_your-key-here

# Optional: OpenAI API key (if you want to use OpenAI)
# OPENAI_API_KEY=sk-your-key-here

# === Database ===
DATABASE_URL=sqlite+aiosqlite:///./data/agentforge.db

# === API Configuration ===
ALLOWED_ORIGINS=http://localhost:3000

# === Storage ===
UPLOAD_DIR=/app/data/uploads
CHROMA_DIR=/app/data/chroma

# === Optional: Tool API Keys ===
# Tavily Search (faster than DuckDuckGo, but paid)
# TAVILY_API_KEY=tvly-your-key-here

# SMTP Email (if you want send_email tool)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
